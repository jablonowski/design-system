{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "components": {
      "projectType": "library",
      "root": "",
      "sourceRoot": "src",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "tsConfig": ".storybook/tsconfig.json",
            "outputPath": "dist-storybook",
            "index": "",
            "main": "",
            "styles": [
              "src/styles/_material-overrides.scss"
            ],
            "stylePreprocessorOptions": {
              "includePaths": [
                "node_modules/@jablonowski/tokens/dist/ds-bank"
              ]
            }
          }
        },
        "storybook": {
          "builder": "@storybook/angular:start-storybook",
          "options": {
            "configDir": ".storybook",
            "browserTarget": "components:build",
            "compodoc": false,
            "port": 6006,
            "styles": [
              "src/styles/_material-overrides.scss"
            ],
            "stylePreprocessorOptions": {
              "includePaths": [
                "node_modules/@jablonowski/tokens/dist/ds-bank"
              ]
            }
          }
        },
        "build-storybook": {
          "builder": "@storybook/angular:build-storybook",
          "options": {
            "configDir": ".storybook",
            "browserTarget": "components:build",
            "compodoc": false,
            "styles": [
              "src/styles/_material-overrides.scss"
            ],
            "stylePreprocessorOptions": {
              "includePaths": [
                "node_modules/@jablonowski/tokens/dist/ds-bank"
              ]
            }
          }
        }
      }
    }
  }
}
