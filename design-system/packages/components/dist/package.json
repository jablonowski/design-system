{
  "name": "@jablonowski/components",
  "version": "1.0.8",
  "description": "Angular component library built on Angular Material, themed with design system tokens.",
  "peerDependencies": {
    "@angular/cdk": "^19.0.0",
    "@angular/common": "^19.0.0",
    "@angular/core": "^19.0.0",
    "@angular/material": "^19.0.0"
  },
  "dependencies": {
    "@jablonowski/tokens": "^1.0.0",
    "tslib": "^2.3.0"
  },
  "keywords": [
    "angular",
    "component-library",
    "design-system",
    "material-design"
  ],
  "author": "Mateusz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/design-system.git",
    "directory": "packages/components"
  },
  "publishConfig": {
    "access": "public"
  },
  "module": "fesm2022/jablonowski-components.mjs",
  "typings": "index.d.ts",
  "exports": {
    "./package.json": {
      "default": "./package.json"
    },
    ".": {
      "types": "./index.d.ts",
      "default": "./fesm2022/jablonowski-components.mjs"
    }
  },
  "sideEffects": false
}
