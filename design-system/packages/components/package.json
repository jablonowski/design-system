{
  "name": "@jablonowski/components",
  "version": "1.4.0",
  "description": "Angular component library built on Angular Material, themed with design system tokens.",
  "scripts": {
    "build": "ng-packagr -p ng-package.json",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "publish:lib": "npm run build && cd dist && npm publish --access public",
    "release": "npm run build && cd dist && npm version patch && npm publish --access public",
    "release:minor": "npm run build && cd dist && npm version minor && npm publish --access public",
    "release:major": "npm run build && cd dist && npm version major && npm publish --access public",
    "storybook": "ng run components:storybook",
    "build-storybook": "ng run components:build-storybook"
  },
  "peerDependencies": {
    "@angular/cdk": "^19.0.0",
    "@angular/common": "^19.0.0",
    "@angular/core": "^19.0.0",
    "@angular/material": "^19.0.0"
  },
  "dependencies": {
    "@jablonowski/tokens": "^1.2.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.7",
    "@angular/animations": "^19.2.20",
    "@angular/cdk": "^19.2.19",
    "@angular/cli": "^21.2.7",
    "@angular/common": "^19.0.0",
    "@angular/compiler": "^19.0.0",
    "@angular/compiler-cli": "^19.0.0",
    "@angular/core": "^19.0.0",
    "@angular/forms": "^19.2.20",
    "@angular/material": "^19.2.19",
    "@angular/platform-browser": "^19.2.20",
    "@angular/platform-browser-dynamic": "^21.2.9",
    "@angular/router": "^21.2.9",
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/angular": "^8.6.18",
    "ng-packagr": "^19.0.0",
    "storybook": "^8.6.18",
    "typescript": "~5.5.0",
    "zone.js": "^0.16.1"
  },
  "keywords": [
    "angular",
    "component-library",
    "design-system",
    "material-design"
  ],
  "author": "Mateusz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/design-system.git",
    "directory": "packages/components"
  },
  "publishConfig": {
    "access": "public"
  }
}
